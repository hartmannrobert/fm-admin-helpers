{
  "manifest_version": 3,
  "name": "Fusion Manage Helper",
  "version": "0.1.0",
  "action": {
    "default_title": "FM",
    "default_popup": "popup/popup.html"
  },
  "permissions": ["storage", "activeTab"],
  "options_ui": {
    "page": "options/options.html"
  },
  "host_permissions": [
    "https://*.autodeskplm360.net/plm/*",
    "https://*.autodeskplm360.net/admin*",
    "https://*.autodeskplm360.net/script.form*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["data/default-snippets.json"],
      "matches": ["https://*.autodeskplm360.net/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://*.autodeskplm360.net/script.form*"],
      "js": ["content/ace-capture.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://*.autodeskplm360.net/plm/*",
        "https://*.autodeskplm360.net/admin*",
        "https://*.autodeskplm360.net/script.form*"
      ],
      "js": [
        "content/config-bridge.js",
        "content/utils.js",
        "content/snippet-modal.js",
        "content/feature-buttons.js",
        "content/feature-admin-titles.js",
        "content/feature-fieldid.js",
        "content/feature-scripts.js",
        "content/feature-security.js",
        "content/feature-workspace.js",
        "content/bootstrap.js"
      ],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
